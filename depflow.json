{
  "$schema": ".depflow/schema.json",
  "flowFolder": ".depflow",
  "outDir": "build",
  "tsconfig": "tsconfig.json",
  "dependencies": [
    {
      "name": "NetFeez/vizui",
      "repo": "https://github.com/NetFeez/vizui.git",
      "tag": "main",
      "builder": [
        {
          "run": [
            "npm install",
            "npm run compile"
          ],
          "extract": [
            {
              "from": "build/**/*.d.ts",
              "to": "lib/vizui",
              "replacer": "^build"
            }
          ]
        }
      ],
      "resolver": [
        {
          "alias": "vizui",
          "target": "lib/vizui/Vizui.d.ts"
        },
        {
          "alias": "vizui/*",
          "target": "lib/vizui/*"
        }
      ]
    },
    {
      "name": "NetFeez/qrcode",
      "repo": "https://github.com/NetFeez/qrcode.git",
      "tag": "main",
      "builder": [
        {
          "run": [
            "npm install",
            "npm run compile"
          ],
          "extract": [
            {
              "from": "build/**/*.d.ts",
              "to": "lib/qrcode",
              "replacer": "^build"
            }
          ]
        }
      ],
      "resolver": [
        {
          "alias": "qrcode",
          "target": "lib/qrcode/QR.d.ts"
        },
        {
          "alias": "qrcode/*",
          "target": "lib/qrcode/*"
        }
      ]
    }
  ],
  "npmDependencies": []
}